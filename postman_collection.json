{
  "info": {
    "_postman_id": "ecommerce-gym-tpo-collection",
    "name": "API Ecommerce Gym TPO",
    "description": "Colección completa de endpoints para la API Ecommerce Gym TPO.\n\n**Instrucciones:**\n1. Ejecutar 'Login ADMIN' o 'Login CLIENTE' → el token se guarda automáticamente en la variable {{token}}.\n2. Todos los endpoints protegidos usan {{token}} en el header Authorization.\n3. Cambiar {{baseUrl}} si el servidor corre en otro puerto.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "token",   "value": "",                      "type": "string" }
  ],
  "item": [

    {
      "name": "🔐 Autenticación",
      "item": [
        {
          "name": "Register CLIENTE",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nuevo@cliente.com\",\n  \"password\": \"Cliente123!\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var json = pm.response.json();",
                "if (json.access_token) {",
                "    pm.collectionVariables.set('token', json.access_token);",
                "    pm.test('Token recibido', () => pm.expect(json.access_token).to.be.a('string'));",
                "}",
                "pm.test('Status 200', () => pm.response.to.have.status(200));"
              ]
            }
          }]
        },
        {
          "name": "Register ADMIN",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin2@gym.com\",\n  \"password\": \"Admin1234!\",\n  \"rol\": \"ADMIN\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "var json = pm.response.json();",
                "if (json.access_token) {",
                "    pm.collectionVariables.set('token', json.access_token);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Login ADMIN",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/authenticate", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","authenticate"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@gym.com\",\n  \"password\": \"Admin1234!\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "var json = pm.response.json();",
                "pm.test('Token en respuesta', () => pm.expect(json.access_token).to.be.a('string'));",
                "pm.collectionVariables.set('token', json.access_token);",
                "console.log('Token guardado:', json.access_token);"
              ]
            }
          }]
        },
        {
          "name": "Login CLIENTE",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/authenticate", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","authenticate"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cliente@gym.com\",\n  \"password\": \"Cliente123!\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "var json = pm.response.json();",
                "pm.test('Token en respuesta', () => pm.expect(json.access_token).to.be.a('string'));",
                "pm.collectionVariables.set('token', json.access_token);",
                "console.log('Token CLIENTE guardado:', json.access_token);"
              ]
            }
          }]
        },
        {
          "name": "Login con credenciales incorrectas (401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/authenticate", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","authenticate"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@gym.com\",\n  \"password\": \"passwordIncorrecta\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Debe devolver 401', () => pm.response.to.have.status(401));"
              ]
            }
          }]
        }
      ]
    },

